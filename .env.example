# Supabase
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# AI Providers (xAI / Grok — primary, used by Supabase Edge Functions)
XAI_API_KEY=your-xai-api-key

# Optional: Additional AI providers for multi-model routing
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Agent Runtime — when set, the app uses LiveAgentRuntime (live mode)
# which calls the Supabase Edge Function 'agent-run' for real LLM execution.
# When NOT set, the app uses MockAgentRuntime (development mode, no real AI).
# The endpoint should be your Supabase Edge Function URL, e.g.:
#   https://your-project.supabase.co/functions/v1/agent-run
VITE_AGENT_RUNTIME_ENDPOINT=

# Runtime mode: enqueue (durable worker queue — production), inline (legacy
# edge-function execution), or mock. Production builds set enqueue in CI
# (see .github/workflows/deploy.yml and DEPLOY.md).
VITE_RUNTIME_MODE=

# Optional: API key for authenticating to the edge function.
# If not set, the Supabase session access token is used instead.
VITE_AGENT_RUNTIME_API_KEY=

# Deprecated fallback names. Prefer VITE_AGENT_RUNTIME_* above.
VITE_HERMES_RUNTIME_ENDPOINT=
VITE_HERMES_RUNTIME_API_KEY=


# Frontend — static SPA build served by nginx.
# Build-time VITE_* values are baked into the bundle (they are public values;
# provider API keys NEVER go here).

FROM node:22-slim AS build
WORKDIR /app

ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_PUBLISHABLE_KEY
ARG VITE_RUNTIME_MODE
ARG VITE_AGENT_RUNTIME_ENDPOINT
ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL \
    VITE_SUPABASE_PUBLISHABLE_KEY=$VITE_SUPABASE_PUBLISHABLE_KEY \
    VITE_RUNTIME_MODE=$VITE_RUNTIME_MODE \
    VITE_AGENT_RUNTIME_ENDPOINT=$VITE_AGENT_RUNTIME_ENDPOINT

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
